    @AuraEnabled
    public static Oppgave getOppgaveById(String oppgaveId) {
        OppgaveService service = new OppgaveService();
        HttpResponse response = service.getOppgaveById(oppgaveId);
        if (response.getStatusCode() == 200) {
            Oppgave oppgave = (Oppgave) JSON.deserialize(response.getBody(), Oppgave.class);
            return oppgave;
        } else {
            logger.httpError(
                'Error getting oppgave by ID',
                response,
                null,
                CRM_ApplicationDomain.Domain.NKS,
                service.getTransactionId()
            );
            logger.publish();
        }
        return null;
    }

    @AuraEnabled
    public static List<Oppgave> getAllAssignedOpenOppgaver(String navIdent) {
        OppgaveService service = new OppgaveService();
        CRM_OppgaveQueryList query = new CRM_OppgaveQueryList();
        query.tilordnetRessurs = navIdent;
        query.statuskategori = OppgaveStatuskategori.AAPEN;
        HttpResponse response = service.queryOppgave(query);
        if (response.getStatusCode() == 200) {
            OppgaveQueryResponseWrapper oppgaver = (OppgaveQueryResponseWrapper) JSON.deserialize(
                response.getBody(),
                OppgaveQueryResponseWrapper.class
            );
            return oppgaver.oppgaver;
        } else {
            logger.httpError(
                'Error getting assigned open oppgaver',
                response,
                null,
                CRM_ApplicationDomain.Domain.NKS,
                service.getTransactionId()
            );
            logger.publish();
        }
        return null;
    }

    @AuraEnabled
    public static List<Oppgave> getOpenOppgaver(Id personId, Integer offset) {
        OppgaveService service = new OppgaveService();
        CRM_OppgaveQueryList query = new CRM_OppgaveQueryList();
        Person__c person = [SELECT Id, Name FROM Person__c WHERE Id = :personId LIMIT 1];

        if (person == null) {
            return null;
        }

        query.aktoerId = new List<String>{ person.Name };
        query.statuskategori = OppgaveStatuskategori.AAPEN;
        query.returnLimit = 100;
        if (offset != null && offset > 0) {
            query.offset = offset;
        }
        HttpResponse response = service.queryOppgave(query);
        if (response.getStatusCode() == 200) {
            OppgaveQueryResponseWrapper oppgaver = (OppgaveQueryResponseWrapper) JSON.deserialize(
                response.getBody(),
                OppgaveQueryResponseWrapper.class
            );
            return oppgaver.oppgaver;
        } else {
            logger.httpError(
                'Error getting open oppgaver for person',
                response,
                null,
                CRM_ApplicationDomain.Domain.NKS,
                service.getTransactionId()
            );
            logger.publish();
        }
        return null;
    }

    @AuraEnabled
    public static List<Oppgave> getAllOppgaver(Id personId, Integer offset) {
        OppgaveService service = new OppgaveService();
        CRM_OppgaveQueryList query = new CRM_OppgaveQueryList();
        query.aktoerId = new List<String>{ personId };
        query.returnLimit = 100;
        if (offset != null && offset > 0) {
            query.offset = offset;
        }
        HttpResponse response = service.queryOppgave(query);
        if (response.getStatusCode() == 200) {
            OppgaveQueryResponseWrapper oppgaver = (OppgaveQueryResponseWrapper) JSON.deserialize(
                response.getBody(),
                OppgaveQueryResponseWrapper.class
            );
            return oppgaver.oppgaver;
        } else {
            logger.httpError(
                'Error getting all oppgaver for person',
                response,
                null,
                CRM_ApplicationDomain.Domain.NKS,
                service.getTransactionId()
            );
            logger.publish();
        }
        return null;
    }

    private class OppgaveQueryResponseWrapper {
        private Integer antallTreffTotalt;
        private List<Oppgave> oppgaver;
    }
}