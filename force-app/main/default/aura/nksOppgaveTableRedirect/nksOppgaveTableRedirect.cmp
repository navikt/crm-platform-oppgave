<aura:component implements="lightning:isUrlAddressable" access="global">
    <aura:attribute name="pageReference" type="Object" />
    <aura:attribute name="ownedByRunningUser" type="Boolean" default="false" />
    <aura:attribute name="personIdent" type="String" />
    <aura:attribute name="actorId" type="String" />

    <aura:handler name="init" value="{!this}" action="{!c.init}" />
    <lightning:workspaceAPI aura:id="workspace" />

    <c:nksOppgaveTable
        owned-by-running-user="{!v.ownedByRunningUser}"
        person-ident="{!v.personIdent}"
        actor-id="{!v.actorId}"
    />
</aura:component>
